  "components": {
    "schemas": {
      "Game": {
        "required": [
          "name",
          "description",
          "developer"
        ],
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "name": {
            "maxLength": 250,
            "minLength": 1,
            "type": [
              "null",
              "string"
            ]
          },
          "postedDate": {
            "type": "string",
            "format": "date-time"
          },
          "description": {
            "maxLength": 1000,
            "minLength": 2,
            "type": [
              "null",
              "string"
            ]
          },
          "mainTag": {
            "type": "string"
          },
          "thumbnailPath": {
            "type": "string"
          },
          "rating": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "developer": {
            "type": [
              "null",
              "string"
            ]
          },
          "isPublished": {
            "type": "boolean"
          }
        }
      }
    }
